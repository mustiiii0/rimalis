NODE_ENV=development
PORT=8080
CORS_ORIGIN=http://localhost:8000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rimalis
DB_SSL=false
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
TRUST_PROXY=false
SECURITY_ALERT_WEBHOOK=

# SMTP (required on Render for admin 2FA + notification emails)
# Example SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_PORT=587, SMTP_USER=apikey, SMTP_PASS=<API_KEY>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SENDGRID_API_KEY=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=support@rimalis.se
SUPPORT_EMAIL=support@rimalis.se

# Preferred on PaaS: SendGrid Web API (HTTPS/443, avoids blocked SMTP ports)
SENDGRID_API_KEY=

# Seed users (dev: passwords auto-generated if blank; prod: must be set)
ADMIN_SEED_EMAIL=admin@rimalis.se
ADMIN_SEED_PASSWORD=Admin1234

USER_SEED_EMAIL=user@rimalis.se
USER_SEED_PASSWORD=User1234

# Storage: local or r2
STORAGE_DRIVER=local

# Cloudflare R2 (S3-compatible)
R2_ENDPOINT=
R2_REGION=auto
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=https://pub-490049e56b1047dc9719e1e24e1d379a.r2.dev

# Automatic orphan cleanup cron (daily, server local time)
MEDIA_CLEANUP_CRON_ENABLED=true
MEDIA_CLEANUP_CRON_TIME=03:20
MEDIA_CLEANUP_OLDER_THAN_DAYS=30
MEDIA_CLEANUP_PREFIX=uploads/images/
MEDIA_CLEANUP_MAX_DELETE=5000
MEDIA_CLEANUP_RUN_ON_START=false

# Storage: local
# LOCAL_STORAGE_PATH=/tmp/rimalis
# LOCAL_STORAGE_PATH=/Users/musti/Projects/rimalis/storage
